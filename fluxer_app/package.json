{
	"name": "fluxer_app",
	"version": "0.0.0",
	"private": true,
	"description": "Fluxer is a free and open source instant messaging and VoIP chat app built for friends, groups, and communities.",
	"homepage": "https://fluxer.app",
	"author": "Fluxer Platform AB <support@fluxer.app>",
	"sideEffects": [
		"*.css",
		"**/*.css"
	],
	"type": "module",
	"exports": {
		".": "./src/index.tsx",
		"./src/*": "./src/*"
	},
	"scripts": {
		"build": "pnpm wasm:codegen && pnpm generate:colors && pnpm generate:message-layout && pnpm generate:theme-variables && pnpm generate:masks && pnpm generate:css-types && pnpm lingui:compile && rm -rf dist && rspack build --mode production && pnpm tsx scripts/build-sw.mjs",
		"dev": "TOKIO_WORKER_THREADS=4 RAYON_NUM_THREADS=4 cargo run --manifest-path ../tools/ci/Cargo.toml -- app-dev-server",
		"test": "vitest run",
		"bench:member-list": "vitest bench --run src/features/member/utils/MemberListRangeUtils.bench.ts src/features/member/state/MemberListStateMachines.bench.ts src/features/member/state/MemberSidebar.bench.ts",
		"bench:gif-picker": "vitest bench --run src/features/channel/components/pickers/gif/GifPickerStateMachine.bench.ts src/features/channel/components/pickers/gif/GifPickerGridData.bench.ts src/features/channel/components/pickers/gif/GifPickerLoadingSkeletonGridLayout.bench.ts src/features/channel/components/pickers/shared/MasonryListComputer.bench.ts",
		"bench:messages": "vitest bench --run src/features/messaging/utils/MessageGroupingUtils.bench.ts src/features/channel/components/ChannelMessageStreamUtils.bench.ts src/features/messaging/components/markdown/MarkdownRendering.bench.ts src/features/channel/components/MessageAttachmentUtils.bench.ts src/features/messaging/utils/MessagePaginationUtils.bench.ts src/features/platform/utils/ScrollPosition.bench.ts src/features/messaging/state/ReactionStateMachine.bench.ts",
		"test:watch": "vitest",
		"typecheck": "pnpm wasm:codegen && pnpm generate:message-layout && pnpm generate:theme-variables && pnpm generate:masks && pnpm generate:css-types && tsgo --noEmit",
		"typecheck:only": "tsgo --noEmit",
		"check:message-layout": "pnpm tsx scripts/GenerateMessageLayoutCss.ts --check",
		"generate:colors": "pnpm tsx scripts/GenerateColorSystem.ts",
		"generate:css-types": "pnpm tsx scripts/GenerateCssTypes.ts",
		"generate:css-types:watch": "pnpm tsx scripts/GenerateCssTypes.ts --watch",
		"generate:emoji-sprites": "pnpm tsx scripts/GenerateEmojiSprites.ts",
		"generate:message-layout": "pnpm tsx scripts/GenerateMessageLayoutCss.ts",
		"generate:theme-variables": "pnpm tsx scripts/GenerateThemeVariables.ts",
		"generate:masks": "pnpm tsx scripts/GenerateAvatarMasks.ts",
		"theming:data-flx:check": "node scripts/add-data-flx-attributes.mjs --check",
		"theming:data-flx:dry": "node scripts/add-data-flx-attributes.mjs --dry-run",
		"theming:data-flx:write": "node scripts/add-data-flx-attributes.mjs --write",
		"i18n:auto": "cargo run --quiet --manifest-path ../tools/i18n_auto/Cargo.toml",
		"i18n:compile": "pnpm lingui:compile",
		"i18n:extract": "pnpm lingui:extract",
		"i18n:refresh": "pnpm i18n:extract && pnpm i18n:auto && pnpm i18n:compile",
		"lingui:compile": "lingui compile --strict",
		"lingui:extract": "lingui extract --clean",
		"tsc:all": "pnpm wasm:codegen && pnpm tsgo -p tsconfig.json",
		"wasm:bench": "pnpm wasm:codegen && node scripts/BenchLibfluxcore.mjs",
		"wasm:bench:download-realmedia": "node scripts/BenchLibfluxcore.mjs --download-realmedia",
		"wasm:bench:highres": "pnpm wasm:codegen && node scripts/BenchLibfluxcore.mjs --profile=highres",
		"wasm:bench:realmedia": "pnpm wasm:codegen && node scripts/BenchLibfluxcore.mjs --profile=realmedia --offline",
		"wasm:codegen": "cargo run --locked --manifest-path ../tools/ci/Cargo.toml -- build-app-wasm",
		"wasm:codegen:simd": "FLUXCORE_WASM_SIMD=1 pnpm wasm:codegen"
	},
	"browserslist": [
		"chrome >= 47",
		"edge >= 12",
		"firefox >= 44",
		"safari >= 9",
		"ios >= 9",
		"last 2 versions",
		"not dead",
		"> 0.2%",
		"not op_mini all"
	],
